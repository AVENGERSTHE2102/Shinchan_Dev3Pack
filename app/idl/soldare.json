{
  "version": "0.1.0",
  "name": "soldare",
  "address": "HTiYVYKAGyZptRer8Q3HGZY3ghjm5fo15BVwk7NtWyuA",
  "instructions": [
    {
      "name": "createDare",
      "accounts": [
        { "name": "dare_account", "isMut": true, "isSigner": false },
        { "name": "creator", "isMut": true, "isSigner": true },
        { "name": "system_program", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "dare_hash", "type": { "array": ["u8", 32] } },
        { "name": "bounty_lamports", "type": "u64" },
        { "name": "expires_in_seconds", "type": "i64" },
        { "name": "dare_id", "type": "string" }
      ]
    },
    {
      "name": "acceptDare",
      "accounts": [
        { "name": "dare_account", "isMut": true, "isSigner": false },
        { "name": "recipient", "isMut": false, "isSigner": true }
      ],
      "args": []
    },
    {
      "name": "approveDare",
      "accounts": [
        { "name": "dare_account", "isMut": true, "isSigner": false },
        { "name": "creator", "isMut": true, "isSigner": true },
        { "name": "recipient", "isMut": true, "isSigner": false }
      ],
      "args": [{ "name": "proof_hash", "type": { "array": ["u8", 32] } }]
    },
    {
      "name": "reclaim",
      "accounts": [
        { "name": "dare_account", "isMut": true, "isSigner": false },
        { "name": "creator", "isMut": true, "isSigner": true }
      ],
      "args": []
    }
  ],
  "accounts": [
    {
      "name": "DareAccount",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "creator", "type": "publicKey" },
          { "name": "recipient", "type": "publicKey" },
          { "name": "bounty", "type": "u64" },
          { "name": "dare_hash", "type": { "array": ["u8", 32] } },
          { "name": "proof_hash", "type": { "array": ["u8", 32] } },
          { "name": "expires_at", "type": "i64" },
          { "name": "status", "type": { "defined": "DareStatus" } },
          { "name": "bump", "type": "u8" },
          { "name": "dare_id", "type": "string" }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "DareStatus",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Open" },
          { "name": "Accepted" },
          { "name": "Approved" },
          { "name": "Expired" }
        ]
      }
    }
  ],
  "events": [
    {
      "name": "DareCreated",
      "fields": [
        { "name": "dareId", "type": "string", "index": false },
        { "name": "creator", "type": "publicKey", "index": false },
        { "name": "bounty", "type": "u64", "index": false },
        { "name": "expiresAt", "type": "i64", "index": false }
      ]
    },
    {
      "name": "DareAccepted",
      "fields": [
        { "name": "dareId", "type": "string", "index": false },
        { "name": "recipient", "type": "publicKey", "index": false }
      ]
    },
    {
      "name": "ApprovalEvent",
      "fields": [
        { "name": "dareId", "type": "string", "index": false },
        { "name": "recipient", "type": "publicKey", "index": false },
        { "name": "bountyLamports", "type": "u64", "index": false },
        { "name": "proofHash", "type": { "array": ["u8", 32] }, "index": false }
      ]
    },
    {
      "name": "DareExpired",
      "fields": [
        { "name": "dareId", "type": "string", "index": false },
        { "name": "bountyReturned", "type": "u64", "index": false }
      ]
    }
  ],
  "errors": [
    {
      "code": 6000,
      "name": "BountyTooSmall",
      "msg": "Bounty must be at least 0.001 SOL (1,000,000 lamports)"
    },
    {
      "code": 6001,
      "name": "InvalidExpiry",
      "msg": "Expiry must be between 1 second and 7 days"
    },
    {
      "code": 6002,
      "name": "DareIdTooLong",
      "msg": "Dare ID must be 36 characters or fewer (UUID format)"
    },
    {
      "code": 6003,
      "name": "InvalidStatus",
      "msg": "Dare is not in the correct status for this instruction"
    },
    {
      "code": 6004,
      "name": "DareExpired",
      "msg": "Dare has expired — the deadline has passed"
    },
    {
      "code": 6005,
      "name": "NotYetExpired",
      "msg": "Dare has not yet expired — cannot reclaim before deadline"
    },
    {
      "code": 6006,
      "name": "Unauthorized",
      "msg": "Only the dare creator can call this instruction"
    },
    {
      "code": 6007,
      "name": "AlreadyApproved",
      "msg": "Dare has already been approved and paid out"
    }
  ]
}
